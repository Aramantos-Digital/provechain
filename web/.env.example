# Stripe Configuration (Required for paid tiers)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PRICE_ID_FOUNDING_MEMBER=price_your_price_id_here
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=price_your_price_id_here

# Auth: Aramantos Core Supabase (identity + authentication)
# Get from Core's Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-core-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_core_anon_key_here

# Data: ProveChain's own Supabase (proofs, tags, teams, etc.)
# Get from ProveChain's Supabase dashboard → Settings → API
PROVECHAIN_SUPABASE_URL=https://your-provechain-project.supabase.co
PROVECHAIN_SUPABASE_SERVICE_ROLE_KEY=your_provechain_service_role_key_here

# Aramantos Core API (for validate-token, tier checks)
CORE_API_URL=https://your-core-api.run.app
SERVICE_API_KEY=your_service_api_key_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Job Security (Optional - recommended for production)
CRON_SECRET=your_random_secret_here

# Email Configuration (Optional - for expiry notifications)
# RESEND_API_KEY=re_your_api_key_here
# RESEND_FROM_EMAIL=ProveChain <no-reply@provechain.io>
