# Stripe Keys (get these from https://dashboard.stripe.com/test/apikeys)
# Use TEST keys for development (they start with pk_test_ and sk_test_)

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe Price IDs (create these in Stripe Dashboard → Products)
# Founding Member: €5/month
STRIPE_PRICE_ID_FOUNDING_MEMBER=price_founding_member_id_here

# Pro: €9/month
STRIPE_PRICE_ID_PRO=price_pro_id_here

# Success/Cancel URLs (for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3001
