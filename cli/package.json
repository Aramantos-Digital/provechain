{
  "name": "@aramantos/provechain-cli",
  "version": "1.0.1",
  "description": "ProveChain CLI - Cryptographic proof of existence for your files",
  "type": "module",
  "bin": {
    "provechain": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "author": "John Doyle <support@aramantos.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aramantos/provechain.git"
  },
